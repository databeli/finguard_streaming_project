{
  "datasets": [
    {
      "name": "high_risk_customers",
      "displayName": "High Risk Customers Count",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as high_risk_count\n",
        "FROM\n",
        "  finguard.silver.customers\n",
        "WHERE\n",
        "  risk_score > 70"
      ]
    },
    {
      "name": "total_transactions_today",
      "displayName": "Total Transactions Today",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as transaction_count\n",
        "FROM\n",
        "  finguard.silver.transactions\n",
        "WHERE\n",
        "  DATE(transaction_timestamp) = CURRENT_DATE()"
      ]
    },
    {
      "name": "avg_transaction_amount",
      "displayName": "Average Transaction Amount",
      "queryLines": [
        "SELECT\n",
        "  AVG(amount) as avg_amount\n",
        "FROM\n",
        "  finguard.silver.transactions\n",
        "WHERE\n",
        "  DATE(transaction_timestamp) = CURRENT_DATE()"
      ]
    },
    {
      "name": "total_alerts_today",
      "displayName": "Total Alerts Today",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as alert_count\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      alert_id,\n",
        "      alert_timestamp\n",
        "    FROM\n",
        "      finguard.gold.fraud_card_alert\n",
        "    WHERE\n",
        "      DATE(alert_timestamp) = CURRENT_DATE()\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      alert_id,\n",
        "      alert_timestamp\n",
        "    FROM\n",
        "      finguard.gold.high_value_transactions_alert\n",
        "    WHERE\n",
        "      DATE(alert_timestamp) = CURRENT_DATE()\n",
        "  )"
      ]
    },
    {
      "name": "alert_status_distribution",
      "displayName": "Alert Status Distribution",
      "queryLines": [
        "SELECT\n",
        "  status,\n",
        "  COUNT(*) as alert_count\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      transaction_status as status\n",
        "    FROM\n",
        "      finguard.gold.fraud_card_alert\n",
        "    WHERE\n",
        "      alert_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      status\n",
        "    FROM\n",
        "      finguard.gold.high_value_transactions_alert\n",
        "    WHERE\n",
        "      alert_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS\n",
        "  )\n",
        "GROUP BY\n",
        "  status"
      ]
    },
    {
      "name": "top_customers_by_alerts",
      "displayName": "Top Customers by Alert Count",
      "queryLines": [
        "SELECT\n",
        "  customer_name,\n",
        "  COUNT(*) as alert_count\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      customer_name\n",
        "    FROM\n",
        "      finguard.gold.fraud_card_alert\n",
        "    WHERE\n",
        "      alert_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      customer_name\n",
        "    FROM\n",
        "      finguard.gold.high_value_transactions_alert\n",
        "    WHERE\n",
        "      alert_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS\n",
        "  )\n",
        "GROUP BY\n",
        "  customer_name\n",
        "ORDER BY\n",
        "  alert_count DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "alert_trends",
      "displayName": "Alert Trends Over Time",
      "queryLines": [
        "SELECT\n",
        "  DATE_TRUNC('hour', alert_timestamp) as alert_hour,\n",
        "  COUNT(*) as alert_count\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      alert_timestamp\n",
        "    FROM\n",
        "      finguard.gold.fraud_card_alert\n",
        "    WHERE\n",
        "      alert_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 24 HOURS\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      alert_timestamp\n",
        "    FROM\n",
        "      finguard.gold.high_value_transactions_alert\n",
        "    WHERE\n",
        "      alert_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 24 HOURS\n",
        "  )\n",
        "GROUP BY\n",
        "  DATE_TRUNC('hour', alert_timestamp)\n",
        "ORDER BY\n",
        "  alert_hour"
      ]
    },
    {
      "name": "alert_type_breakdown",
      "displayName": "Alert Type Breakdown",
      "queryLines": [
        "SELECT\n",
        "  alert_type,\n",
        "  COUNT(*) as alert_count\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      alert_type\n",
        "    FROM\n",
        "      finguard.gold.fraud_card_alert\n",
        "    WHERE\n",
        "      alert_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 24 HOURS\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      alert_type\n",
        "    FROM\n",
        "      finguard.gold.high_value_transactions_alert\n",
        "    WHERE\n",
        "      alert_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 24 HOURS\n",
        "  )\n",
        "GROUP BY\n",
        "  alert_type"
      ]
    },
    {
      "name": "transaction_volume_by_minute",
      "displayName": "Transaction Volume by Minute",
      "queryLines": [
        "SELECT\n",
        "  DATE_TRUNC('minute', transaction_timestamp) as transaction_minute,\n",
        "  COUNT(*) as transaction_count\n",
        "FROM\n",
        "  finguard.silver.transactions\n",
        "WHERE\n",
        "  transaction_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 24 HOURS\n",
        "GROUP BY\n",
        "  DATE_TRUNC('minute', transaction_timestamp)\n",
        "ORDER BY\n",
        "  transaction_minute"
      ]
    },
    {
      "name": "intl_vs_domestic",
      "displayName": "International vs Domestic Transactions",
      "queryLines": [
        "SELECT\n",
        "  CASE\n",
        "    WHEN is_international = true THEN 'International'\n",
        "    ELSE 'Domestic'\n",
        "  END as transaction_type,\n",
        "  COUNT(*) as transaction_count\n",
        "FROM\n",
        "  finguard.silver.transactions\n",
        "WHERE\n",
        "  transaction_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS\n",
        "GROUP BY\n",
        "  is_international"
      ]
    },
    {
      "name": "top_merchants",
      "displayName": "Top Merchants by Transaction Count",
      "queryLines": [
        "SELECT\n",
        "  merchant_name,\n",
        "  COUNT(*) as transaction_count\n",
        "FROM\n",
        "  finguard.silver.transactions\n",
        "WHERE\n",
        "  transaction_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS\n",
        "GROUP BY\n",
        "  merchant_name\n",
        "ORDER BY\n",
        "  transaction_count DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "transaction_by_merchant_category",
      "displayName": "Transaction Amount by Merchant Category",
      "queryLines": [
        "SELECT\n",
        "  merchant_category,\n",
        "  SUM(amount) as total_amount\n",
        "FROM\n",
        "  finguard.silver.transactions\n",
        "WHERE\n",
        "  transaction_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS\n",
        "GROUP BY\n",
        "  merchant_category\n",
        "ORDER BY\n",
        "  total_amount DESC"
      ]
    },
    {
      "name": "payment_channel_distribution",
      "displayName": "Payment Channel Distribution",
      "queryLines": [
        "SELECT\n",
        "  payment_channel,\n",
        "  COUNT(*) as transaction_count\n",
        "FROM\n",
        "  finguard.silver.transactions\n",
        "WHERE\n",
        "  transaction_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS\n",
        "GROUP BY\n",
        "  payment_channel\n",
        "ORDER BY\n",
        "  transaction_count DESC"
      ]
    },
    {
      "name": "transactions_by_country",
      "displayName": "Transaction Heatmap by Country",
      "queryLines": [
        "SELECT\n",
        "  country,\n",
        "  COUNT(*) as transaction_count,\n",
        "  SUM(amount) as total_amount\n",
        "FROM\n",
        "  finguard.silver.transactions\n",
        "WHERE\n",
        "  transaction_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS\n",
        "GROUP BY\n",
        "  country\n",
        "ORDER BY\n",
        "  transaction_count DESC"
      ]
    },
    {
      "name": "risk_level_distribution",
      "displayName": "Risk Level Distribution from Watchlist",
      "queryLines": [
        "SELECT\n",
        "  risk_level,\n",
        "  COUNT(*) as count\n",
        "FROM\n",
        "  finguard.silver.fraud_watchlist\n",
        "WHERE\n",
        "  status = 'active'\n",
        "GROUP BY\n",
        "  risk_level\n",
        "ORDER BY\n",
        "  risk_level"
      ]
    }
  ],
